rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && 'admin' in request.auth.token
        && request.auth.token.admin == true;
    }

    function validPreferences(preferences) {
      return preferences is map
        && preferences.keys().hasOnly(['favoriteGenres', 'newsletter'])
        && preferences.favoriteGenres is list
        && preferences.favoriteGenres.size() <= 12
        && preferences.newsletter is bool;
    }

    function validCustomerProfile(data) {
      return data.keys().hasOnly([
          'displayName', 'email', 'role', 'preferences', 'createdAt', 'updatedAt'
        ])
        && data.displayName is string
        && data.displayName.size() <= 100
        && data.email is string
        && data.role == 'customer'
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (!('preferences' in data) || validPreferences(data.preferences));
    }

    function validCartLine(bookId, data) {
      return data.keys().hasOnly(['bookId', 'quantity', 'updatedAt'])
        && data.bookId == bookId
        && data.quantity is int
        && data.quantity >= 1
        && data.quantity <= 99
        && data.updatedAt is timestamp;
    }

    function validWishlistEntry(bookId, data) {
      return data.keys().hasOnly(['bookId', 'addedAt'])
        && data.bookId == bookId
        && data.addedAt is timestamp;
    }

    match /books/{bookId} {
      allow read: if resource.data.status == 'active' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /genres/{genreId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && validCustomerProfile(request.resource.data);
      allow update: if isOwner(uid)
        && request.resource.data.role == resource.data.role
        && validCustomerProfile(request.resource.data);
      allow delete: if isAdmin();

      match /cart/{bookId} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && validCartLine(bookId, request.resource.data);
      }

      match /wishlist/{bookId} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && validWishlistEntry(bookId, request.resource.data);
      }
    }

    match /orders/{orderId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Order totals and inventory must be created by trusted server code using
      // the Admin SDK, which bypasses client security rules.
      allow create: if false;
      allow update, delete: if isAdmin();
    }
  }
}
