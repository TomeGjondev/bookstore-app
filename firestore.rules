rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && 'admin' in request.auth.token
        && request.auth.token.admin == true;
    }

    match /books/{bookId} {
      allow read: if resource.data.status == 'active' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /genres/{genreId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.role == 'customer';
      allow update: if isOwner(uid)
        && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();

      match /cart/{bookId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /wishlist/{bookId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /orders/{orderId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
